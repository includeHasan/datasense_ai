OPENAI_API_KEY=
OPENAI_MODEL_GENERATION=gpt-5.4-mini
PORT=4000
SOURCE_TTL_MINUTES=60
REPAIR_MAX_ATTEMPTS=2
MAX_SAMPLE_ROWS=20
# Max uploaded-file size in MB (CSV/JSON/XLSX). Defaults to 128 to cover the
# ~100MB target dataset size; without this, uploads are capped at 1MB.
MAX_UPLOAD_MB=128
JWT_SECRET=
# Secret used to encrypt user-provided third-party LLM API keys at rest
# (AES-256-GCM). Optional in dev: if left empty the encryption key is derived
# from JWT_SECRET. In PRODUCTION set a dedicated, long random value here so
# that rotating JWT_SECRET does not invalidate every stored credential.
CREDENTIALS_SECRET=
# Free LLM-backed queries per user per calendar month, using the app's own
# OPENAI_API_KEY. After this, a user must add their own OpenAI-compatible
# credentials (API key + optional base URL + model) to keep querying.
FREE_QUERIES_PER_MONTH=5
FRONTEND_ORIGIN=http://localhost:3000
# MongoDB must be running locally (e.g. `mongod` or `docker run -p 27017:27017 mongo`)
# for auth (and future persistence features like conversations/dashboards) to work.
MONGODB_URI=mongodb://localhost:27017/datasense

# --- DB source connection safety (multi-tenant hosted SaaS hardening) ---
# Disabled by default: in a hosted multi-tenant deployment, allowing SQLite
# "connection strings" (server filesystem paths) lets any authenticated user
# open arbitrary server-readable files, including other tenants' data. Only
# enable this on trusted, self-hosted/single-operator deployments.
ALLOW_FILE_DB_SOURCES=false
# Comma-separated list of exact hostnames that are exempt from the
# private/internal-IP rejection applied to user-supplied Postgres/MySQL
# connection strings (SSRF guard). Use this for legitimate cases such as a
# docker-internal Postgres host during local dev/testing. Empty by default.
ALLOWED_INTERNAL_DB_HOSTS=

# --- LangSmith ---
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
